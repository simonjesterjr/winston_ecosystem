{
  "version": 1,
  "description": "Hard MCP allowlist + cron duty guards for Cromwell (sessionKey cron:<job-id>). Enforced by nanobot ToolRegistry/AgentProgressHook patch — soft FORBIDDEN prompts are not enough. See issue 2026-07-13 placeholder-path hallucination + 2026-07-20 DAR leak.",
  "defaults": {
    "identical_fail_limit": 2
  },
  "default_for_unlisted_cron_job": {
    "mcp_allow": [],
    "note": "Unknown cron jobs get no MCP tools until listed here."
  },
  "jobs": {
    "market-snapshot-open": {
      "mcp_allow": ["wv2_market_snapshot"],
      "mcp_require": ["wv2_market_snapshot"],
      "builtin_deny": ["read_file", "write_file", "edit_file"],
      "force_args": {},
      "identical_fail_limit": 2
    },
    "market-snapshot-hourly": {
      "mcp_allow": ["wv2_market_snapshot"],
      "mcp_require": ["wv2_market_snapshot"],
      "builtin_deny": ["read_file", "write_file", "edit_file"],
      "force_args": {},
      "identical_fail_limit": 2
    },
    "eod-daily-report": {
      "mcp_allow": ["wv2_get_daily_activity_report"],
      "mcp_require": ["wv2_get_daily_activity_report"],
      "builtin_deny": ["read_file", "write_file", "edit_file"],
      "force_args": {
        "wv2_get_daily_activity_report": { "fetch_only": true }
      },
      "identical_fail_limit": 2
    },
    "dm-sync-events": {
      "mcp_allow": ["dm_get_cromwell_events"],
      "mcp_require": ["dm_get_cromwell_events"],
      "builtin_deny": ["read_file", "write_file", "edit_file"],
      "force_args": {},
      "identical_fail_limit": 2
    },
    "ecosystem-status-daily": {
      "mcp_allow": [
        "wv2_list_portfolios",
        "wv2_list_pending_actions",
        "wv2_get_daily_activity_report",
        "wut_list_portfolios",
        "dm_get_cromwell_events"
      ],
      "mcp_require": [
        "wv2_list_portfolios",
        "wut_list_portfolios",
        "dm_get_cromwell_events"
      ],
      "builtin_deny": ["read_file", "write_file", "edit_file"],
      "force_args": {
        "wv2_get_daily_activity_report": { "fetch_only": true }
      },
      "identical_fail_limit": 2
    }
  }
}
