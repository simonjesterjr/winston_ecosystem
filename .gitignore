# Credentials / secrets (never commit)
deployment/eodhd.env

# === Audit / integration logs (see ADR-004) ===
# Log *contents* (JSONL events, webhook receipts, etc.) are NEVER committed.
# The directory layout, partitions (mcp/, webhook/, wv2/, dm/ etc.), and
# contracts live in docs/ (ADR-004-ecosystem-audit-log.md and related).
# This blanket + the nested .gitignore ensures no log data enters the tree
# in any clone or commit.
logs/

# The .gitignore that ships the detailed ignore rules must be tracked so
# that `git clone` distributes the protection automatically.
!logs/audit/.gitignore

# Any stray *.log files anywhere in the tree
*.log

# Editor / OS noise
.DS_Store
*.swp
*~
.idea/
.vscode/

# Local environment
.env
.env.local
.env.*
*.env

# Temporary files
tmp/
*.tmp
